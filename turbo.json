{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "AI_PROVIDER",
    "OPENAI_API_KEY",
    "OPENAI_BASE_URL",
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_BASE_URL",
    "CUSTOM_AI_API_KEY",
    "CUSTOM_AI_BASE_URL",
    "AI_SUMMARY_MODEL",
    "AI_CHAT_MODEL",
    "AI_TAG_MODEL",
    "AI_EMBEDDING_MODEL",
    "STORAGE_PROVIDER",
    "R2_ENDPOINT",
    "R2_ACCESS_KEY",
    "R2_SECRET_KEY",
    "R2_BUCKET",
    "R2_PUBLIC_BASE_URL",
    "QINIU_ACCESS_KEY",
    "QINIU_SECRET_KEY",
    "QINIU_BUCKET",
    "QINIU_PUBLIC_BASE_URL",
    "QINIU_UPLOAD_ENDPOINT",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "FEED_SEARCH_ENDPOINT",
    "FEED_SEARCH_API_KEY",
    "FEED_REFRESH_BASE_URL",
    "FEED_CRON_SECRET"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "prisma/client/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
