{
  "name": "mewmo",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "pnpm test:unit",
    "test:unit": "tsx --test tests/*.test.mjs tests/unit/*.test.mjs && vitest run --dir tests/unit --exclude '**/*.mjs' && turbo run test",
    "test:integration": "tsx tooling/run-api-integration-tests.mjs",
    "test:theme": "node tooling/check-theme-colors.mjs",
    "verify": "pnpm lint && pnpm test:unit && pnpm test:theme && pnpm build",
    "db:push": "pnpm --filter @mewmo/db db:push",
    "db:generate": "pnpm --filter @mewmo/db db:generate",
    "onboarding:cleanup": "tsx packages/db/scripts/cleanup-prototype-onboarding.ts",
    "onboarding:cleanup:apply": "tsx packages/db/scripts/cleanup-prototype-onboarding.ts --apply",
    "titles:cleanup": "tsx tooling/run-external-title-backfill.ts",
    "titles:cleanup:apply": "tsx tooling/run-external-title-backfill.ts --apply"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "turbo": "2.10.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
