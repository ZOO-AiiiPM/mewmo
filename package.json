{
  "name": "mewmo",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "node --test tests/*.test.mjs && turbo run test",
    "db:push": "pnpm --filter @mewmo/db db:push",
    "db:generate": "pnpm --filter @mewmo/db db:generate"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "turbo": "2.10.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
