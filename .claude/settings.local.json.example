{
  "//": "复制成 settings.local.json 后：1) 把 autoMemoryDirectory 改为当前项目的绝对路径 2) 不想要某个 hook 删对应 hooks 子段即可（SessionStart = 新 session 状态同步；Stop = turn-reflect 三级提醒）",
  "autoMemoryDirectory": "/绝对路径/到项目/.claude/memory",
  "permissions": {
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-brief.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/turn-reflect.js\""
          }
        ]
      }
    ]
  }
}
