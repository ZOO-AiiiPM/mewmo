generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  password      String?
  avatarUrl     String?   @map("avatar_url")
  image         String?
  provider      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  notes          Note[]
  clips          Clip[]
  feeds          Feed[]
  feedEntries    FeedEntry[]
  aiChats        AiChat[]
  aiContextAttachments AiContextAttachment[]
  tags           Tag[]
  tagPool        TagPool[]
  syncCursors    SyncCursor[]
  knowledgeBases KnowledgeBase[]
  knowledgeFolders KnowledgeFolder[]
  knowledgeItems KnowledgeItem[]
  noteShares     NoteShare[]
  aiActions      AiAction[]
  aiRuns         AiRun[]
  contentEmbeddings ContentEmbedding[]
  contentRelations  ContentRelation[]
  noteInsights      NoteInsight[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @map("user_id")
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model Note {
  id        String    @id @default(cuid())
  slug      String
  title     String
  content   String    @default("")
  summary   String?
  pinned    Boolean   @default(false)
  version   Int       @default(1)
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeItems KnowledgeItem[]
  shares NoteShare[]

  @@unique([userId, slug])
  @@index([userId, deletedAt, updatedAt])
  @@map("notes")
}

model NoteShare {
  id        String    @id @default(cuid())
  noteId    String    @map("note_id")
  ownerId   String    @map("owner_id")
  token     String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  note  Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([noteId, revokedAt])
  @@index([ownerId, revokedAt])
  @@map("note_shares")
}

model Clip {
  id          String    @id @default(cuid())
  url           String
  normalizedUrl String?   @map("normalized_url")
  title         String
  content     String    @default("")
  summary     String?
  favicon     String?
  coverImage  String?   @map("cover_image")
  excerpt     String?
  sourceName  String?   @map("source_name")
  author      String?
  publishedAt DateTime? @map("published_at")
  fetchStatus String    @default("idle") @map("fetch_status")
  fetchError  String?   @map("fetch_error")
  fetchStartedAt DateTime? @map("fetch_started_at")
  fetchedAt   DateTime? @map("fetched_at")
  version     Int       @default(1)
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeItems KnowledgeItem[]

  @@unique([userId, normalizedUrl])
  @@index([userId, deletedAt, updatedAt])
  @@map("clips")
}

model Feed {
  id              String      @id @default(cuid())
  url             String
  type            FeedType    @default(article)
  title           String
  description     String?
  favicon         String?
  refreshInterval Int         @default(3600) @map("refresh_interval")
  lastFetchStartedAt DateTime? @map("last_fetch_started_at")
  lastFetchStatus String       @default("idle") @map("last_fetch_status")
  lastFetchError  String?      @map("last_fetch_error")
  lastFetchCount  Int          @default(0) @map("last_fetch_count")
  lastFetchedAt   DateTime?   @map("last_fetched_at")
  lastSeenEntryUrl String?     @map("last_seen_entry_url")
  version         Int         @default(1)
  userId          String      @map("user_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")
  entries         FeedEntry[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url, type])
  @@index([userId, deletedAt, lastFetchedAt])
  @@map("feeds")
}

model FeedEntry {
  id          String    @id @default(cuid())
  feedId      String    @map("feed_id")
  title       String
  url         String
  content     String    @default("")
  summary     String?
  coverImage  String?   @map("cover_image")
  excerpt     String?
  sourceName  String?   @map("source_name")
  author      String?
  publishedAt DateTime? @map("published_at")
  readAt      DateTime? @map("read_at")
  version     Int       @default(1)
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  feed Feed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeItems KnowledgeItem[]

  @@unique([feedId, url])
  @@index([feedId, deletedAt, publishedAt])
  @@index([userId, deletedAt, readAt])
  @@map("feed_entries")
}

model AiChat {
  id        String      @id @default(cuid())
  title     String
  version   Int         @default(1)
  userId    String      @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")
  messages  AiMessage[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, updatedAt])
  @@map("ai_chats")
}

model AiMessage {
  id        String        @id @default(cuid())
  chatId    String        @map("chat_id")
  role      AiMessageRole
  content   String
  status    AiMessageStatus @default(completed)
  metadata  Json?
  version   Int           @default(1)
  createdAt DateTime      @default(now()) @map("created_at")
  deletedAt DateTime?     @map("deleted_at")

  chat AiChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  contextAttachments AiContextAttachment[]

  @@index([chatId, deletedAt, createdAt])
  @@map("ai_messages")
}

model AiContextAttachment {
  id              String              @id @default(cuid())
  messageId       String              @map("message_id")
  targetType      AiContextTargetType @map("target_type")
  targetId        String              @map("target_id")
  title           String
  sourceUrl       String?             @map("source_url")
  summarySnapshot String?             @map("summary_snapshot")
  contentSnapshot String?             @map("content_snapshot")
  userId          String              @map("user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([targetType, targetId])
  @@index([userId, createdAt])
  @@map("ai_context_attachments")
}

model AiAction {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  toolName         String           @map("tool_name")
  input            Json
  preview          Json
  riskLevel        AiActionRiskLevel @default(write) @map("risk_level")
  executionMode    AiActionExecutionMode @default(server) @map("execution_mode")
  clientEffect     Json?             @map("client_effect")
  status           AiActionStatus    @default(proposed)
  expectedVersion  Int?             @map("expected_version")
  idempotencyKey   String           @map("idempotency_key")
  result           Json?
  errorCode        String?          @map("error_code")
  errorMessage     String?          @map("error_message")
  confirmedAt      DateTime?        @map("confirmed_at")
  executionStartedAt DateTime?      @map("execution_started_at")
  completedAt      DateTime?        @map("completed_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId, status, createdAt])
  @@map("ai_actions")
}

model AiRun {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  kind             AiRunKind
  targetType       AiTargetType @map("target_type")
  targetId         String       @map("target_id")
  inputVersion     Int          @map("input_version")
  inputHash        String?      @map("input_hash")
  idempotencyKey   String       @map("idempotency_key")
  priority         Int          @default(0)
  status           AiRunStatus  @default(queued)
  attempts         Int          @default(0)
  availableAt      DateTime     @default(now()) @map("available_at")
  workerId         String?      @map("worker_id")
  leaseExpiresAt   DateTime?    @map("lease_expires_at")
  startedAt        DateTime?    @map("started_at")
  completedAt      DateTime?    @map("completed_at")
  output           Json?
  errorCode        String?      @map("error_code")
  errorMessage     String?      @map("error_message")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([status, availableAt, priority, createdAt])
  @@index([userId, targetType, targetId, createdAt])
  @@index([workerId, leaseExpiresAt])
  @@map("ai_runs")
}

model ContentEmbedding {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  targetType   AiTargetType @map("target_type")
  targetId     String       @map("target_id")
  inputVersion Int          @map("input_version")
  model        String
  dimensions   Int
  embedding    Json
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType, inputVersion])
  @@map("content_embeddings")
}

model ContentRelation {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  sourceType    AiTargetType @map("source_type")
  sourceId      String       @map("source_id")
  sourceVersion Int          @map("source_version")
  targetType    AiTargetType @map("target_type")
  targetId      String       @map("target_id")
  score         Float
  reason        String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId, targetType, targetId])
  @@index([userId, sourceType, sourceId, score])
  @@index([userId, targetType, targetId])
  @@map("content_relations")
}

model NoteInsight {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  noteId       String          @map("note_id")
  inputVersion Int             @map("input_version")
  kind         NoteInsightKind
  content      String
  data         Json?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId, kind])
  @@index([userId, noteId, inputVersion])
  @@map("note_insights")
}

model Tag {
  id        String     @id @default(cuid())
  name      String
  color     String?
  userId    String     @map("user_id")
  isSystem  Boolean    @default(false) @map("is_system")
  version   Int        @default(1)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  taggables Taggable[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, deletedAt])
  @@map("tags")
}

model Taggable {
  id           String       @id @default(cuid())
  tagId        String       @map("tag_id")
  taggableId   String       @map("taggable_id")
  taggableType TaggableType @map("taggable_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, taggableId, taggableType])
  @@index([taggableId, taggableType])
  @@map("taggables")
}

model TagPool {
  id        String   @id @default(cuid())
  name      String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("tag_pool")
}

model SyncCursor {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  deviceId    String   @map("device_id")
  lastVersion Int      @default(0) @map("last_version")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("sync_cursors")
}

model KnowledgeBase {
  id        String    @id @default(cuid())
  title     String
  icon      String    @default("book")
  position  Int       @default(0)
  version   Int       @default(1)
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders KnowledgeFolder[]
  items   KnowledgeItem[]

  @@index([userId, deletedAt, position])
  @@map("knowledge_bases")
}

model KnowledgeFolder {
  id              String    @id @default(cuid())
  knowledgeBaseId String    @map("knowledge_base_id")
  parentId        String?   @map("parent_id")
  name            String
  depth           Int       @default(0)
  position        Int       @default(0)
  version         Int       @default(1)
  userId          String    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  knowledgeBase KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  parent        KnowledgeFolder?  @relation("KnowledgeFolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children      KnowledgeFolder[] @relation("KnowledgeFolderChildren")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         KnowledgeItem[]

  @@index([knowledgeBaseId, parentId, deletedAt, position])
  @@index([userId, deletedAt])
  @@map("knowledge_folders")
}

model KnowledgeItem {
  id              String              @id @default(cuid())
  knowledgeBaseId String              @map("knowledge_base_id")
  folderId        String?             @map("folder_id")
  kind            KnowledgeItemKind
  noteId          String?             @map("note_id")
  clipId          String?             @map("clip_id")
  feedEntryId     String?             @map("feed_entry_id")
  assetType       KnowledgeAssetType? @map("asset_type")
  title           String?
  summary         String?
  sourceName      String?             @map("source_name")
  sourceUrl       String?             @map("source_url")
  position        Int                 @default(0)
  version         Int                 @default(1)
  userId          String              @map("user_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  folder        KnowledgeFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  note          Note?            @relation(fields: [noteId], references: [id], onDelete: SetNull)
  clip          Clip?            @relation(fields: [clipId], references: [id], onDelete: SetNull)
  feedEntry     FeedEntry?       @relation(fields: [feedEntryId], references: [id], onDelete: SetNull)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId, folderId, deletedAt, position])
  @@index([userId, deletedAt])
  @@index([noteId])
  @@index([clipId])
  @@index([feedEntryId])
  @@map("knowledge_items")
}

enum AiMessageRole {
  user
  assistant
  tool
}

enum AiMessageStatus {
  pending
  completed
  failed
  cancelled
}

enum AiActionRiskLevel {
  write
  destructive
}

enum AiActionExecutionMode {
  server
  client
}

enum AiActionStatus {
  proposed
  confirmed
  executing
  succeeded
  failed
  cancelled
}

enum AiRunKind {
  summary
  embedding
  relation
  note_insight
}

enum AiRunStatus {
  queued
  running
  succeeded
  failed
  superseded
}

enum AiTargetType {
  note
  clip
  feed_entry
}

enum NoteInsightKind {
  completeness
  duplicate_viewpoint
  viewpoint_change
}

enum AiContextTargetType {
  note
  clip
  feed_entry
}

enum TaggableType {
  note
  clip
  feed_entry
}

enum FeedType {
  article
  media
  video
  podcast
}

enum KnowledgeItemKind {
  note
  clip
  feed_entry
  asset
}

enum KnowledgeAssetType {
  pdf
  ebook
}
