{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "name": "sqlite:vibe.db" }]
    },
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "name": "sqlite:vibe.db" }]
    },
    {
      "identifier": "sql:allow-select",
      "allow": [{ "name": "sqlite:vibe.db" }]
    }
  ]
}
