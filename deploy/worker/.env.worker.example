# Shared background runtime
NODE_ENV=production
DATABASE_URL=
AI_WORKFLOW_BATCH_LIMIT=10
AI_WORKFLOW_CONCURRENCY=2

# Shared AI Runtime configuration
AI_PROVIDER=openai
AI_MODEL_SUMMARY=
AI_MODEL_EMBEDDING=
AI_MODEL_RECOMMENDATION=
AI_MODEL_NOTE_INSIGHT=

# ZOO-64 hybrid retrieval / reranking
# Embedding vector dimensions for the pgvector shadow column (defaults to 1536 when unset).
AI_EMBEDDING_DIMENSIONS=1536
# Reranker is optional: leave AI_RERANK_PROVIDER/AI_RERANK_API_KEY empty to keep the fail-open
# passthrough (candidates stay in RRF order). Set provider=voyage + API key to enable reranking.
AI_RERANK_PROVIDER=
AI_RERANK_MODEL=
AI_RERANK_API_KEY=
AI_RERANK_BASE_URL=
AI_RERANK_TIMEOUT_MS=
AI_RERANK_MAX_CANDIDATES=

# Temporary migration fallbacks; prefer the AI_MODEL_* names above.
AI_SUMMARY_MODEL=
AI_EMBEDDING_MODEL=
AI_CHAT_MODEL=

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic provider (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Custom OpenAI-compatible provider (used when AI_PROVIDER=custom)
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=
