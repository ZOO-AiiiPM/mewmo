# Worker runtime and feed Cron
NODE_ENV=production
DATABASE_URL=
REDIS_URL=

# AI summary jobs
AI_PROVIDER=openai
AI_SUMMARY_MODEL=

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic provider (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Custom OpenAI-compatible provider (used when AI_PROVIDER=custom)
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=
