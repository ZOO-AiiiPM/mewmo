NODE_ENV=production
DATABASE_URL=

# Web sets the same value under AGENT_INTERNAL_SECRET.
AGENT_IDENTITY_SECRET=
AGENT_IDENTITY_ISSUER=mewmo-web
AGENT_IDENTITY_AUDIENCE=mewmo-agent
AGENT_HOST=0.0.0.0
AGENT_PORT=3101
AGENT_MAX_STEPS=6
AGENT_TIMEOUT_MS=45000

# Web access tools (Jina Reader/Search). Leave JINA_API_KEY empty to disable
# web_search / web_fetch. Store the key only in Local/Preview/Production secrets;
# never commit it or write it to logs.
JINA_API_KEY=
AGENT_WEB_TIMEOUT_MS=20000
AGENT_WEB_SEARCH_BUDGET=2
AGENT_WEB_FETCH_BUDGET=5
AGENT_WEB_CACHE_TTL_MS=300000
AGENT_WEB_CACHE_MAX_ENTRIES=128

AI_PROVIDER=openai
AI_MODEL_AGENT_CHAT=
AI_MODEL_DEEP_INSIGHT=

# Temporary migration fallback; prefer AI_MODEL_AGENT_CHAT.
AI_CHAT_MODEL=

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic provider (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Custom OpenAI-compatible provider (used when AI_PROVIDER=custom)
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=
