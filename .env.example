# ============================================
# mewmo 2.0 环境变量
# 复制为 .env.local 后填入实际值
# ============================================

# === 本地开发（docker compose up -d 自动起） ===
DATABASE_URL="postgresql://mewmo:mewmo@localhost:5432/mewmo_dev?schema=public"
REDIS_URL="redis://localhost:6379"

# === 认证（本地开发可用默认值） ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-replace-in-production"

# === 订阅后台刷新 ===
# 本地默认跟随 NEXTAUTH_URL；网页服务不在 3000 时可单独覆盖
# FEED_REFRESH_BASE_URL="http://localhost:3000"
# 生产环境建议设置，并同时配置到后台刷新进程
# FEED_CRON_SECRET="replace-with-long-random-secret"

# === OAuth（各自申请；占位值可通过 build，真实 Google 登录需替换） ===
GOOGLE_CLIENT_ID="google-client-id"
GOOGLE_CLIENT_SECRET="google-client-secret"

# === AI（团队共享，找 zoo 拿；占位值只用于本地 build） ===
AI_PROVIDER="openai"
OPENAI_API_KEY="openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
ANTHROPIC_API_KEY="anthropic-api-key"
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
CUSTOM_AI_API_KEY="custom-ai-api-key"
CUSTOM_AI_BASE_URL="https://custom.example/v1"
AI_SUMMARY_MODEL="fill-model-id"
AI_CHAT_MODEL="fill-model-id"
AI_TAG_MODEL="fill-model-id"
AI_EMBEDDING_MODEL="fill-model-id"

# === 文件存储 Cloudflare R2（团队共享，找 zoo 拿；占位值只用于本地 build） ===
STORAGE_PROVIDER="r2"
R2_ENDPOINT="https://example.r2.cloudflarestorage.com"
R2_ACCESS_KEY="r2-access-key"
R2_SECRET_KEY="r2-secret-key"
R2_BUCKET="mewmo-files"
R2_PUBLIC_BASE_URL="https://cdn.mewmo.example"

# === 文件存储七牛云 Kodo（无 R2 时可改 STORAGE_PROVIDER 为 qiniu） ===
# STORAGE_PROVIDER="qiniu"
# QINIU_ACCESS_KEY="qiniu-access-key"
# QINIU_SECRET_KEY="qiniu-secret-key"
# QINIU_BUCKET="mewmo-images"
# QINIU_PUBLIC_BASE_URL="http://example.clouddn.com"
# QINIU_UPLOAD_ENDPOINT="https://upload-z2.qiniup.com"

# === 邮件 Resend（团队共享，找 zoo 拿；占位值只用于本地 build） ===
RESEND_API_KEY="resend-api-key"
EMAIL_FROM="Mewmo <login@mewmo.app>"

# === 以下由 Vercel/Neon Integration 自动注入，本地不需要填 ===
# NEON_DATABASE_URL=（Preview Deploy 自动设置）
# VERCEL_URL=（Vercel 自动设置）
