# ============================================
# mewmo 2.0 环境变量
# 复制为 .env.local 后填入实际值
# ============================================

# === 本地开发（docker compose up -d 自动起） ===
DATABASE_URL="postgresql://mewmo:mewmo@localhost:5432/mewmo_dev?schema=public"
REDIS_URL="redis://localhost:6379"

# === 认证（本地开发可用默认值） ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-replace-in-production"

# === OAuth（各自申请，本地不填也能跑邮箱登录） ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === AI（团队共享，找 zoo 拿） ===
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# === 文件存储 Cloudflare R2（团队共享，找 zoo 拿） ===
R2_ENDPOINT=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="mewmo-files"

# === 邮件 Resend（团队共享，找 zoo 拿） ===
RESEND_API_KEY=""

# === 以下由 Vercel/Neon Integration 自动注入，本地不需要填 ===
# NEON_DATABASE_URL=（Preview Deploy 自动设置）
# VERCEL_URL=（Vercel 自动设置）
